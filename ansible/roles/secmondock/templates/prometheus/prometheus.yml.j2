global:
  scrape_interval: 5s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "proxmox-nodes"
    static_configs:
      - targets:
        - "172.27.80.4:9100"
        - "172.27.80.5:9100"
        - "172.27.80.6:9100"
        - "172.27.80.7:9100"
        - "172.27.80.9:9100"
        - "172.27.80.10:9100"
        - "172.27.80.11:9100"
        - "172.27.80.12:9100"

  - job_name: "nagios"
    static_configs:
      - targets:
        - "172.27.85.5:9927"

  - job_name: "graylog"
    metrics_path: "/api/metrics/prometheus"
    static_configs:
      - targets:
        - "172.27.84.3:9833"

  - job_name: "wazuh"
    metrics_path: "/prometheus"
    static_configs:
      - targets:
        - "172.27.84.3:55000"
